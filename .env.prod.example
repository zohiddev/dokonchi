# ============================================================
# Dokonchi production muhit o'zgaruvchilari
# Serverda nusxasini ".env" deb saqlang:  cp .env.prod.example .env
# Keyin CHANGE_ME larni o'zgartiring.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=dokonchi
POSTGRES_PASSWORD=CHANGE_ME_kuchli_parol
POSTGRES_DB=dokonchi

# --- JWT (uzun, tasodifiy satr) ---
# Generatsiya:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_random_64_belgi
JWT_EXPIRES_IN=7d

# --- CORS ---
# Same-origin (nginx) bo'lgani uchun "*" qoldirsa ham bo'ladi
CORS_ORIGIN=*

# --- Telegram bot (ixtiyoriy) ---
# @BotFather dan token. Bo'sh qoldirilsa bot o'chiq bo'ladi (ilova normal ishlaydi).
TELEGRAM_BOT_TOKEN=
SHOP_NAME=Dokonchi

# --- Birinchi admin foydalanuvchi (faqat seed-prod uchun) ---
ADMIN_NAME=Admin
ADMIN_PHONE=+998901234567
ADMIN_PASSWORD=CHANGE_ME_admin_parol
