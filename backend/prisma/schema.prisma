generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SOTUVCHI
}

enum Unit {
  KG
  DONA
  LITR
  QOP
  QUTI
}

enum PaymentType {
  NAQD
  KARTA
  NASIYA
}

enum SaleMode {
  PIECE
  PACK
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String   @unique
  passwordHash String
  role         Role     @default(SOTUVCHI)
  sales        Sale[]
  createdAt    DateTime @default(now())
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id               Int        @id @default(autoincrement())
  name             String
  categoryId       Int
  category         Category   @relation(fields: [categoryId], references: [id])
  barcode          String?    @unique
  baseUnit         Unit
  packSize         Decimal?   @db.Decimal(12, 3)
  // Pachka/bulk birlik yorlig'i (erkin matn): "fleyka", "karobka", "qop"...
  packUnit         String?
  defaultSalePrice Decimal?   @db.Decimal(14, 2)
  // Butun pachka sotuv narxi (standart). null = pachka qilib sotilmaydi (masalan tuxum)
  packSalePrice    Decimal?   @db.Decimal(14, 2)
  isActive         Boolean    @default(true)
  batches          Batch[]
  saleItems        SaleItem[]
  createdAt        DateTime   @default(now())
}

model Supplier {
  id       Int               @id @default(autoincrement())
  name     String
  phone    String?
  notes    String?
  // Telegram bildirishnoma uchun chat id (ta'minotchi botga telefonini ulaganda saqlanadi)
  telegramChatId String?
  batches    Batch[]
  deliveries Delivery[]
  payments   SupplierPayment[]
}

// Bitta yetkazma (kirim) — bir ta'minotchidan bir kelishda kelgan bir nechta mahsulot.
// Har bir mahsulot qatori alohida Batch (stock lot) bo'lib qoladi; Delivery ularni guruhlaydi.
model Delivery {
  id           Int               @id @default(autoincrement())
  supplierId   Int?
  supplier     Supplier?         @relation(fields: [supplierId], references: [id])
  receivedDate DateTime
  weekLabel    String
  notes        String?
  batches      Batch[]
  payments     SupplierPayment[]
  createdAt    DateTime          @default(now())

  @@index([receivedDate])
}

model Batch {
  id                Int             @id @default(autoincrement())
  productId         Int
  product           Product         @relation(fields: [productId], references: [id])
  supplierId        Int?
  supplier          Supplier?       @relation(fields: [supplierId], references: [id])
  // Qaysi yetkazmaga tegishli (bir yetkazmada bir nechta mahsulot/batch bo'lishi mumkin)
  deliveryId        Int?
  delivery          Delivery?       @relation(fields: [deliveryId], references: [id])
  receivedDate      DateTime
  weekLabel         String
  quantityReceived  Decimal         @db.Decimal(14, 3)
  quantityRemaining Decimal         @db.Decimal(14, 3)
  // Dona tannarx. Pachkadan hisoblanganda yaxlitlash siljimasligi uchun 4 xonali
  costPricePerUnit  Decimal         @db.Decimal(14, 4)
  salePricePerUnit  Decimal?        @db.Decimal(14, 2)
  // Pachka bo'yicha kirim narxi (provenance/ko'rsatish uchun)
  costPerPack       Decimal?        @db.Decimal(14, 2)
  // Butun pachka sotuv narxi — shu partiya uchun override (product.packSalePrice ustidan)
  packSalePrice     Decimal?        @db.Decimal(14, 2)
  notes             String?
  allocations       SaleItemBatch[]
  payments          SupplierPayment[]
  createdAt         DateTime        @default(now())

  @@index([productId, receivedDate])
  @@index([deliveryId])
}

model Customer {
  id          Int           @id @default(autoincrement())
  name        String
  phone       String?
  notes       String?
  // Appdan oldingi eski (boshlang'ich) qarz — onboarding paytida kiritiladi
  openingDebt Decimal       @default(0) @db.Decimal(14, 2)
  // Telegram bildirishnoma uchun chat id (mijoz botga telefonini ulaganda saqlanadi).
  // Bitta chat = bitta mijoz: ulashda eski bog'lanish ilova mantig'ida bekor qilinadi.
  telegramChatId String?
  createdAt   DateTime      @default(now())
  sales       Sale[]
  payments    DebtPayment[]
  debtCharges DebtCharge[]
}

model Sale {
  id          Int         @id @default(autoincrement())
  saleDate    DateTime    @default(now())
  userId      Int
  user        User        @relation(fields: [userId], references: [id])
  customerId  Int?
  customer    Customer?   @relation(fields: [customerId], references: [id])
  paymentType PaymentType
  totalAmount Decimal     @db.Decimal(14, 2)
  totalCost   Decimal     @db.Decimal(14, 2)
  notes       String?
  items       SaleItem[]

  @@index([saleDate])
}

model SaleItem {
  id        Int             @id @default(autoincrement())
  saleId    Int
  sale      Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId Int
  product   Product         @relation(fields: [productId], references: [id])
  quantity  Decimal         @db.Decimal(14, 3)
  unitPrice Decimal         @db.Decimal(14, 2)
  lineTotal Decimal         @db.Decimal(14, 2)
  // Sotuv usuli: dona (PIECE) yoki butun pachka (PACK). packCount — PACK bo'lsa nechta pachka
  saleMode  SaleMode        @default(PIECE)
  packCount Decimal?        @db.Decimal(14, 3)
  batches   SaleItemBatch[]
}

model SaleItemBatch {
  id         Int      @id @default(autoincrement())
  saleItemId Int
  saleItem   SaleItem @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  batchId    Int
  batch      Batch    @relation(fields: [batchId], references: [id])
  quantity   Decimal  @db.Decimal(14, 3)
  costPrice  Decimal  @db.Decimal(14, 2)
}

model DebtPayment {
  id          Int      @id @default(autoincrement())
  customerId  Int
  customer    Customer @relation(fields: [customerId], references: [id])
  amount      Decimal  @db.Decimal(14, 2)
  paymentDate DateTime @default(now())
  notes       String?
}

// Qo'lda qo'shilgan eski/oldingi qarz — appdan tashqari kelishuv yoki o'tmishdagi qarz.
// openingDebt kabi qarz balansini oshiradi, lekin har biri alohida sana+izoh bilan saqlanadi.
// Pul harakati emas — kassaga/hisobotga ta'sir qilmaydi.
model DebtCharge {
  id          Int      @id @default(autoincrement())
  customerId  Int
  customer    Customer @relation(fields: [customerId], references: [id])
  amount      Decimal  @db.Decimal(14, 2)
  chargeDate  DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())

  @@index([customerId])
}

// Ta'minotchiga to'lov — yetkazma qo'shilganda (boshlang'ich) yoki keyin alohida.
// deliveryId — butun yetkazmaga to'lov; batchId — eski yagona-batch yo'li (moslik uchun).
model SupplierPayment {
  id          Int       @id @default(autoincrement())
  supplierId  Int
  supplier    Supplier  @relation(fields: [supplierId], references: [id])
  batchId     Int?
  batch       Batch?    @relation(fields: [batchId], references: [id])
  deliveryId  Int?
  delivery    Delivery? @relation(fields: [deliveryId], references: [id])
  amount      Decimal   @db.Decimal(14, 2)
  paymentDate DateTime  @default(now())
  notes       String?

  @@index([supplierId])
}

model Expense {
  id          Int      @id @default(autoincrement())
  expenseDate DateTime @default(now())
  category    String
  amount      Decimal  @db.Decimal(14, 2)
  notes       String?
}
